PHOENIX_API_KEY=your_phoenix_api_key_here
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space/v1/traces
GOOGLE_CLOUD_PROJECT=mallpulse-hackathon
GOOGLE_GENAI_USE_VERTEXAI=1

# Gemini 3 Flash Preview (requires global location)
GEMINI_MODEL=gemini-3-flash-preview
GOOGLE_CLOUD_LOCATION=global

# Fallback to Gemini 2.5 Flash (if Gemini 3 is unavailable):
# GEMINI_MODEL=gemini-2.5-flash
# GOOGLE_CLOUD_LOCATION=us-central1
